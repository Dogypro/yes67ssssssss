--[[
    JS AUTO COUNTER v12.2 (The "Actually Functional" Edition)
    ========================================================
    Fixes:
    1. Direct Service Retrieval (Skips Knit.OnStart hang)
    2. Dynamic Signal Binding (Connects even if game is mid-match)
    3. Debug Console Logging (Check F9 to see if signals are firing)
]]

if _G.__AC_RUN then _G.__AC_RUN = false task.wait(0.5) end
_G.__AC_RUN = true
_G.__AC_CONNS = {}

local function track(c) table.insert(_G.__AC_CONNS, c) return c end

local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local Knit = require(RS:WaitForChild("Knit"):WaitForChild("Knit"))

-- Toggles
local beforeOn = true
local debugMode = true -- Check F9 to see detection logs
local MAX_DISTANCE = 20

-- Helper to find the counter key dynamically
local function getCounterKey()
    -- We assume '3' based on common moveset layouts, 
    -- but you can change this to Enum.KeyCode.F or whatever your counter is.
    return Enum.KeyCode.Three 
end

local function fireCounter()
    if not _G.__AC_RUN then return end
    local key = getCounterKey()
    
    if debugMode then print("!!! COUNTER TRIGGERED !!!") end
    
    VIM:SendKeyEvent(true, key, false, game)
    task.wait(0.03)
    VIM:SendKeyEvent(false, key, false, game)
end

-- ============================================================
-- THE CORE LOGIC (Directly tapping the services)
-- ============================================================

local function HookServices()
    -- Attempt to get services immediately
    local successH, HitboxService = pcall(function() return Knit.GetService("HitboxService") end)
    local successHandi, HandicapService = pcall(function() return Knit.GetService("HandicapService") end)

    if successH and HitboxService.Hitbox then
        if debugMode then print("Connected to HitboxService") end
        track(HitboxService.Hitbox:Connect(function(attacker, ...)
            if not beforeOn or attacker == char then return end
            
            local enemyRoot = attacker:FindFirstChild("HumanoidRootPart")
            local myRoot = char:FindFirstChild("HumanoidRootPart")
            
            if enemyRoot and myRoot then
                local dist = (enemyRoot.Position - myRoot.Position).Magnitude
                if dist <= MAX_DISTANCE then
                    if debugMode then print("Detection: Hitbox started by " .. attacker.Name) end
                    fireCounter()
                end
            end
        end))
    end

    if successHandi and HandicapService.Effects then
        if debugMode then print("Connected to HandicapService") end
        track(HandicapService.Effects:Connect(function(part, effectType, attacker, ...)
            if not beforeOn or effectType ~= "Swing" then return end
            
            -- Your game's HandicapController passes the attacker model here
            if attacker and attacker ~= char and attacker:IsA("Model") then
                local enemyRoot = attacker:FindFirstChild("HumanoidRootPart")
                local myRoot = char:FindFirstChild("HumanoidRootPart")
                
                if enemyRoot and myRoot then
                    local dist = (enemyRoot.Position - myRoot.Position).Magnitude
                    if dist <= MAX_DISTANCE then
                        if debugMode then print("Detection: Swing detected from " .. attacker.Name) end
                        fireCounter()
                    end
                end
            end
        end))
    end
end

-- Run the hook
task.spawn(HookServices)

