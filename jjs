	toggleB.BackgroundColor3 = counterOn and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(35, 35, 45)
	toggleB.TextColor3 = counterOn and Color3.new(1, 1, 1) or Color3.fromRGB(200, 200, 210)
