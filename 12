--[[
AUTO RAID v64

Lag fix: _G.__AR_CLEANUP stores all connections.
On re-run, disconnects EVERYTHING from previous run first.
No more stacking connections.

Difficulty: applies to NEXT raid creation (can't change current raid).
]]

-- ============================================================
-- CLEANUP: disconnect all old connections from previous runs
-- ============================================================
if _G.__AR_CLEANUP then
	pcall(function()
		for _, conn in _G.__AR_CLEANUP do
			pcall(function() conn:Disconnect() end)
		end
	end)
	_G.__AR_RUN = false -- stop old main loop
	_G.__AR_TAP = false -- stop old tap loops
	task.wait(0.2) -- let old threads die
end
_G.__AR_CLEANUP = {}
_G.__AR_RUN = true
_G.__AR_TAP = false

local CONNS = _G.__AR_CLEANUP
local function track(conn) table.insert(CONNS, conn) return conn end

