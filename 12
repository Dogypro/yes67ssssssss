-- Kill FX
local FX_CLASSES = {"ParticleEmitter","Trail","Beam","Fire","Smoke","Sparkles","Sound","PointLight","SpotLight","SurfaceLight","BillboardGui","SurfaceGui","Decal","Texture"}
local function nukeInstance(obj) for _, cls in FX_CLASSES do if obj:IsA(cls) then if obj:IsA("Sound") then pcall(function() obj.Volume=0 obj:Stop() end) elseif obj:IsA("Decal") or obj:IsA("Texture") then pcall(function() obj.Transparency=1 end) else pcall(function() obj.Enabled=false end) end return end end end

local function enableFXKiller()
	pcall(function() for _, obj in workspace:GetDescendants() do nukeInstance(obj) end end)
	pcall(function() game:GetService("Lighting").GlobalShadows=false end)
	pcall(function() settings().Rendering.QualityLevel=Enum.QualityLevel.Level01 end)
	track(workspace.DescendantAdded:Connect(function(obj) if killFX then task.defer(function() nukeInstance(obj) end) end end))
	pcall(function() track(player.PlayerGui.DescendantAdded:Connect(function(obj) if killFX then task.defer(function() if obj:IsA("ImageLabel") or obj:IsA("Frame") then pcall(function() obj.Visible=false end) end nukeInstance(obj) end) end end)) end)
end

-- Death cancel + instant tap on spawn
track(pcall(function() return workspace.__THINGS.DescendantAdded:Connect(function(obj)
	if obj:IsA("Model") and obj:GetAttribute("BreakableUID") then
		pcall(function() track(obj:GetAttributeChangedSignal("Health"):Connect(function()
			local hp = obj:GetAttribute("Health")
			if hp and hp <= 0 then pcall(function() for _, p in obj:GetDescendants() do if p:IsA("BasePart") then p.Transparency=1 p.CanCollide=false end end end) end
		end)) end)
		if _G.__AR_TAP and SignalMod then
			local uid = obj:GetAttribute("BreakableUID")
			if uid then local n = burst if n == math.huge then n = 999 end for _ = 1, n do SignalMod.Fire("AutoClicker_Nearby", uid) end end
		end
		if killFX then task.defer(function() pcall(function() for _, d in obj:GetDescendants() do nukeInstance(d) end end) end) end
	end
end) end) or nil)

-- Scan
local function getBreakablePosition(model) for _, p in model:GetChildren() do if p:IsA("BasePart") then return p.Position end end return nil end

local function scanForTP()
	local myPos = Vector3.new(0,108,-5700)
	pcall(function() myPos = player.Character.HumanoidRootPart.Position end)
	local best, bestDist = nil, math.huge
	local total, aliveCount = 0, 0
	for _, folder in {"Breakables","AnimatedBreakables"} do
		pcall(function()
			for _, b in workspace.__THINGS[folder]:GetChildren() do
				if b:GetAttribute("BreakableUID") then
					total = total + 1
					local hp = b:GetAttribute("Health") if not hp or hp > 0 then aliveCount = aliveCount + 1 end
					local pos = getBreakablePosition(b)
					if pos then local d = (pos - myPos).Magnitude if d < bestDist then best = pos bestDist = d end end
				end
			end
		end)
	end
	return best, bestDist, total, aliveCount
end

-- Tap loop (checks _G.__AR_TAP so old loops die on re-run)
local function tapWorker(offset)
	task.wait(offset)
	while _G.__AR_TAP do
		pcall(function()
			if not SignalMod then return end
			local n = burst if n == math.huge then n = 999 end
			for _, folder in {"Breakables","AnimatedBreakables"} do
				pcall(function()
					for _, b in workspace.__THINGS[folder]:GetChildren() do
						local uid = b:GetAttribute("BreakableUID")
						if uid then for _ = 1, n do SignalMod.Fire("AutoClicker_Nearby", uid) end end
					end
				end)
			end
			pcall(function() rf("Click"):FireServer() end)
		end)
		task.wait(0.06)
	end
end

-- Boss
local function bossCompleted(idx) return bossData[idx] and bossData[idx].Completed == true end
local function bossSpawned(idx) return bossData[idx] and bossData[idx].Spawned == true end
local function getBossTargetPos(idx) if bossData[idx] and bossData[idx].TargetPosition then return bossData[idx].TargetPosition + Vector3.new(0,3,0) end return BOSS_POS[idx] end

local function doBoss(idx)
	if bossCompleted(idx) then return end
	tp(BOSS_POS[idx]) task.wait(0.1)
	pcall(function() for _, d in workspace.__THINGS:GetDescendants() do if d:IsA("ClickDetector") then fireclickdetector(d) end end end)
	pcall(function() rf("Levers_RequestPull"):FireServer(idx) end)
	task.wait(0.1)
	pcall(function() for _, d in workspace.__THINGS:GetDescendants() do if d:IsA("ClickDetector") then fireclickdetector(d) end end end)
	task.spawn(function() pcall(function() rf("Raids_BossChallenge"):InvokeServer(idx) end) end)
	task.wait(0.15)
	task.spawn(function() pcall(function() rf("Raids_StartBoss"):InvokeServer(idx) end) end)
	local t = tick()
	while not bossSpawned(idx) and not bossCompleted(idx) and (tick()-t) < 3 do task.wait(0.1) end
	if bossCompleted(idx) then return end
	local timeout = (idx == 3) and 10 or 3
	local bossBurst = (idx == 3) and 25 or math.max(burst, 10)
	local bt = tick()
	while not bossCompleted(idx) and (tick()-bt) < timeout do
		local p = getBossTargetPos(idx) if p then tp(p) end
		if SignalMod then pcall(function() for _, folder in {"Breakables","AnimatedBreakables"} do pcall(function() for _, b in workspace.__THINGS[folder]:GetChildren() do local uid = b:GetAttribute("BreakableUID") if uid then for _ = 1, bossBurst do SignalMod.Fire("AutoClicker_Nearby", uid) end end end end) end end) end
		pcall(function() for _, d in workspace.__THINGS:GetDescendants() do if d:IsA("ClickDetector") then fireclickdetector(d) end end end)
		pcall(function() rf("Click"):FireServer() end)
		task.wait(0.05)
	end
	if bossCompleted(idx) then local p = getBossTargetPos(idx) if p then tp(p) end task.wait(0.5) end
end

-- Chests + Creation
local function openChestsAndCreate()
	local ct = ""
	pcall(function() local cur = ClientRaidInstance.GetCurrent() if cur then ct = cur._ct or "" end end)
	if NetworkMod and ct ~= "" then
		task.spawn(function() pcall(function() NetworkMod.Invoke("Raids_CollectReward", "Tier1000Chest", ct) end) end)
		task.spawn(function() pcall(function() NetworkMod.Invoke("Raids_CollectReward", "LootChest", ct) end) end)
		task.spawn(function() pcall(function() NetworkMod.Invoke("Raids_CollectReward", "HugeChest", ct) end) end)
		task.spawn(function() pcall(function() NetworkMod.Invoke("Raids_CollectReward", "TitanicChest", ct) end) end)
		task.spawn(function() pcall(function() NetworkMod.Invoke("Raids_CollectReward", "LeprechaunChest", ct) end) end)
	else
		task.spawn(function() pcall(function() rf("Raids_OpenChest"):InvokeServer("LootChest") end) end)
		task.spawn(function() pcall(function() rf("Raids_OpenChest"):InvokeServer("HugeChest") end) end)
		task.spawn(function() pcall(function() rf("Raids_OpenChest"):InvokeServer("TitanicChest") end) end)
		task.spawn(function() pcall(function() rf("Raids_OpenChest"):InvokeServer("Tier1000Chest") end) end)
		task.spawn(function() pcall(function() rf("Raids_OpenChest"):InvokeServer("LeprechaunChest") end) end)
		task.spawn(function() pcall(function() rf("Raids_CollectReward"):InvokeServer() end) end)
	end
	if modulesOk then
		creatingRaid = true
		local function doCreate()
			local pm = 1 pcall(function() pm = RaidTypes.PartyMode.Solo end)
			local portal pcall(function() local ok, p = pcall(SignalMod.Invoke, "Get Portal Number") if ok and p then portal = p end end)
			if not portal then pcall(function() for i = 1, 10 do if not ClientRaidInstance.GetByPortal(i) then portal = i break end end end) end
			if not portal then creatingRaid = false return end
			local usedDiff = _G.__AR_DIFF
			local ok, s, m, raid = pcall(RaidCmds.Create, { Portal = portal, Difficulty = usedDiff, PartyMode = pm })
			if ok and s and raid then pcall(raid.Join, raid) end
			pcall(function() diffLabel.Text = "Lvl:" .. myLevel .. " | Created:" .. usedDiff end)
			warn("[AR] Created raid at difficulty " .. tostring(usedDiff))
			creatingRaid = false
		end
		local inInst = false pcall(function() inInst = InstancingCmds.IsInInstance() end)
		if inInst then pcall(function() InstancingCmds.Leave(false, true, function() doCreate() end) end)
		else doCreate() end
	end
end

