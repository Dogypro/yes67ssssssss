--[[
JS AUTO COUNTER v8
===================
TEST button to verify Eye Catching fires.
React = counter on damage taken.
Before = counter when Swing aimed at you.

Fix: removed Cancel (was blocking counter activation).
Fix: longer key hold (0.15s instead of 0.07s).
Fix: multiple fire methods tried simultaneously.
]]

if _G.__AC_RUN then _G.__AC_RUN = false task.wait(0.3) end
if _G.__AC_CONNS then for _, c in _G.__AC_CONNS do pcall(function() c:Disconnect() end) end end
_G.__AC_RUN = true
_G.__AC_CONNS = {}
local function track(c) if c then table.insert(_G.__AC_CONNS, c) end return c end

local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")
local VIM pcall(function() VIM = game:GetService("VirtualInputManager") end)

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
track(player.CharacterAdded:Connect(function(c) char = c task.wait(1) connectHealth() end))

local reactOn = false
local beforeOn = false
local counters = 0
local lastFire = 0

-- Find eye catching key from moveset
local EC_KEY = Enum.KeyCode.Three
pcall(function()
	local moveset = char:FindFirstChild("Moveset")
	if moveset then
		local ec = moveset:FindFirstChild("Eye Catching")
		if ec then
			local k = ec:GetAttribute("Key")
			if k == 1 then EC_KEY = Enum.KeyCode.One
			elseif k == 2 then EC_KEY = Enum.KeyCode.Two
			elseif k == 3 then EC_KEY = Enum.KeyCode.Three
			elseif k == 4 then EC_KEY = Enum.KeyCode.Four end
		end
	end
end)

-- ============================================================
-- FIRE EYE CATCHING
-- ============================================================
local function fireCounter()
	if (tick() - lastFire) < 0.2 then return end
	lastFire = tick()
	counters = counters + 1

	-- Method 1: VIM keypress (hold for 0.15s)
	pcall(function()
		if VIM then
			VIM:SendKeyEvent(true, EC_KEY, false, game)
			task.delay(0.15, function()
				pcall(function() VIM:SendKeyEvent(false, EC_KEY, false, game) end)
			end)
		end
	end)

	-- Method 2: Fire EyeCatch remote
	pcall(function()
		local svc = RS.Knit.Knit.Services:FindFirstChild("EyeCatchService")
		if svc and svc.RE then
			local act = svc.RE:FindFirstChild("Activated")
			if act then act:FireServer() end
		end
	end)

	-- Method 3: Fire by service name from moveset attribute
	pcall(function()
		local moveset = char:FindFirstChild("Moveset")
		if moveset then
			local ec = moveset:FindFirstChild("Eye Catching")
			if ec then
				local svcName = ec:GetAttribute("Service")
				if svcName then
					local svc = RS.Knit.Knit.Services:FindFirstChild(svcName)
					if svc and svc.RE then
						local act = svc.RE:FindFirstChild("Activated")
						if act then act:FireServer() end
					end
				end
			end
		end
	end)
end

-- ============================================================
-- REACT: Counter same tick as health drop
-- ============================================================
function connectHealth()
	pcall(function()
		local hum = char and char:WaitForChild("Humanoid", 5)
		if not hum then return end
		local lastHP = hum.Health
		track(hum.HealthChanged:Connect(function(hp)
			if reactOn and hp < lastHP then
				fireCounter()
			end
			lastHP = hp
		end))
	end)
end
connectHealth()

-- ============================================================
-- BEFORE: Counter when we are confirmed target in remotes
-- Also counter on Swing when attacker is very close + facing us
-- ============================================================
pcall(function()
	for _, svc in RS.Knit.Knit.Services:GetChildren() do
		local re = svc:FindFirstChild("RE")
		if not re then continue end
		if svc.Name == "EyeCatchService" then continue end

		for _, remote in re:GetChildren() do
			if not remote:IsA("RemoteEvent") then continue end

			track(remote.OnClientEvent:Connect(function(effectName, ...)
				if not beforeOn then return end
				local args = {...}

				-- Check if our character is directly referenced as a target
				for _, arg in args do
					if typeof(arg) == "Instance" then
						if arg == char or arg == player then
							fireCounter()
							return
						end
						if char and arg:IsDescendantOf(char) then
							fireCounter()
							return
						end
					end
				end

				-- For "Swing" type effects: check if attacker is VERY close + facing us
				if type(effectName) == "string" then
					local e = effectName:lower()
					if e:find("swing") or e:find("slash") or e:find("punch") or e:find("kick") then
						local myHrp = char and char:FindFirstChild("HumanoidRootPart")
						if not myHrp then return end

						for _, arg in args do
							if typeof(arg) == "Instance" and arg:IsA("Model") and arg ~= char then
								local eHrp = arg:FindFirstChild("HumanoidRootPart")
								if eHrp then
									local dist = (eHrp.Position - myHrp.Position).Magnitude
									-- Very close (within actual melee range) AND facing directly at us
									if dist <= 6 then
										local toMe = (myHrp.Position - eHrp.Position).Unit
										local look = eHrp.CFrame.LookVector
										-- dot > 0.7 = facing almost directly at us
										if look:Dot(toMe) > 0.7 then
											-- Check no other player is closer to attacker in their look direction
											local imClosest = true
											for _, p in Players:GetPlayers() do
												if p ~= player and p ~= arg and p.Character then
													local pHrp = p.Character:FindFirstChild("HumanoidRootPart")
													if pHrp then
														local pDist = (pHrp.Position - eHrp.Position).Magnitude
														if pDist < dist then
															local toThem = (pHrp.Position - eHrp.Position).Unit
															if look:Dot(toThem) > 0.7 then
																imClosest = false
																break
															end
														end
													end
												end
											end
											if imClosest then
												fireCounter()
												return
											end
										end
									end
								end
							end
						end
					end
				end
			end))
		end
	end
end)

