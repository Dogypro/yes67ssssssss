local output = {}
local count = 0
local function add(s) table.insert(output, tostring(s)) count = count + 1 end

local function dumpTree(obj, depth, maxDepth)
	local indent = string.rep("  ", depth)
	local info = indent .. obj.ClassName .. " | " .. obj.Name

	pcall(function()
		local attrs = obj:GetAttributes()
		if next(attrs) then
			for k, v in pairs(attrs) do
				info = info .. " [" .. k .. "=" .. tostring(v) .. "]"
			end
		end
	end)

	add(info)

	if obj:IsA("ModuleScript") or obj:IsA("LocalScript") then
		pcall(function()
			local src = decompile(obj)
			if src and #src > 0 then
				add(indent .. "  === SOURCE START (" .. obj:GetFullName() .. ") ===")
				for line in src:gmatch("[^\n]*") do
					add(indent .. "  " .. line)
				end
				add(indent .. "  === SOURCE END ===")
			end
		end)
	end

	if depth < maxDepth then
		pcall(function()
			for _, child in obj:GetChildren() do
				dumpTree(child, depth + 1, maxDepth)
			end
		end)
	end
end

add("========== NETWORK REMOTES ==========")
pcall(function()
	for _, c in game.ReplicatedStorage.Network:GetChildren() do
		add(c.ClassName .. " | " .. c.Name)
	end
end)

