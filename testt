add("\n========== STARTER PLAYER ==========")
pcall(function() dumpTree(game.StarterPlayer, 0, 99) end)

add("\n========== STARTER GUI ==========")
pcall(function() dumpTree(game.StarterGui, 0, 99) end)

add("\n========== WORKSPACE.__THINGS ==========")
pcall(function() dumpTree(workspace.__THINGS, 0, 5) end)

add("\n========== LIGHTING ==========")
pcall(function() dumpTree(game:GetService("Lighting"), 0, 99) end)

add("\n========== PLAYER SCRIPTS ==========")
pcall(function() dumpTree(game.Players.LocalPlayer.PlayerScripts, 0, 99) end)

add("\n========== PLAYER GUI ==========")
pcall(function() dumpTree(game.Players.LocalPlayer.PlayerGui, 0, 3) end)

local result = table.concat(output, "\n")
warn("TOTAL LINES: " .. count)

-- Save as multiple files if too big
local chunkSize = 200000 -- chars per file
if #result > chunkSize then
	local fileNum = 1
	local pos = 1
	while pos <= #result do
		local chunk = string.sub(result, pos, pos + chunkSize - 1)
		pcall(function() writefile("raid_dump_" .. fileNum .. ".txt", chunk) end)
		warn("SAVED raid_dump_" .. fileNum .. ".txt (" .. #chunk .. " chars)")
		fileNum = fileNum + 1
		pos = pos + chunkSize
	end
else
	pcall(function() writefile("raid_dump.txt", result) warn("SAVED raid_dump.txt") end)
end

pcall(function() setclipboard(result) warn("COPIED to clipboard") end)
warn("DONE - " .. #result .. " total characters")
