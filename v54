-- ============================================================
-- CACHED UID SYSTEM + INSTANT KILL ON SPAWN
-- ============================================================
local activeUIDs = {}
local survivedFirstHit = {} -- UIDs that survived burst=current, means we need more

local function instantKill(b)
	local uid = b:GetAttribute("BreakableUID")
	if not uid then return end
	activeUIDs[uid] = true

	-- INSTANT: burst tap the moment it spawns
	if tapOn and SignalMod then
		local n = burst
		if n == math.huge then n = 999 end
		for _ = 1, n do
			SignalMod.Fire("AutoClicker_Nearby", uid)
		end

		-- Check if it survived (after small delay for server to update health)
		task.delay(0.15, function()
			if not b.Parent then return end -- already removed
			local hp = b:GetAttribute("Health")
			if hp and hp > 0 then
				survivedFirstHit[uid] = true
			end
		end)
	end
end

local function onRemoved(b)
	local uid = b:GetAttribute("BreakableUID")
	if uid then
		activeUIDs[uid] = nil
		survivedFirstHit[uid] = nil
	end
end

for _, folder in {"Breakables", "AnimatedBreakables"} do
	pcall(function()
		for _, b in workspace.__THINGS[folder]:GetChildren() do instantKill(b) end
		workspace.__THINGS[folder].ChildAdded:Connect(instantKill)
		workspace.__THINGS[folder].ChildRemoved:Connect(onRemoved)
	end)
end

