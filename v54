-- ============================================================
-- MAIN LOOP: just status display + chest/creation trigger
-- Tapping handled by: ChildAdded instant kill + continuous tap loop
-- ============================================================
local function boostLoop()
	local emptyTime = 0
	local sawBreakables = false

	while RUN do
		pcall(function()
			local l = loc()
			local inRaid = (l == "R")

			if showTimer and raidStart > 0 and inRaid then
				tL.Text = string.format("%.0fs", tick() - raidStart)
			end

			if not raidOnly and not inRaid and not creatingRaid then
				st("Tapping...") rm(breakableCount() .. " targets") db("anywhere")
				task.wait(0.1)
				return
			end

			if not inRaid and not creatingRaid then
				st("Waiting...") db("loc=" .. l)
				chestsDone = false done = false emptyTime = 0 sawBreakables = false
				task.wait(0.5)
				return
			end

			if creatingRaid then
				st("Creating...") db("transitioning")
				task.wait(0.3)
				return
			end

			if not done then
				local r = room if r < 1 then r = 1 end
				local bc = breakableCount()
				st("Room " .. r)
				rm(bc .. " | burst=" .. (burst == math.huge and "INF" or tostring(burst)))

				if bc > 0 then
					sawBreakables = true
					emptyTime = 0
					db(bc .. " targets")
				else
					if sawBreakables then emptyTime = emptyTime + 0.05 end
					if r >= 10 and sawBreakables and emptyTime > 2 then done = true end
					db("empty " .. string.format("%.1f", emptyTime) .. "s")
				end

			elseif not chestsDone then
				st("Chests + Next!")
				tp(CHEST_POS)
				chestsDone = true
				raids = raids + 1
				if showTimer and raidStart > 0 then tL.Text = string.format("Last: %.0fs", tick() - raidStart) end
				rm("Raids: " .. raids)

				-- PARALLEL: chests + creation at same time
				task.spawn(openChestsAndCreate)

			else
				st("Next raid...")
				db(creatingRaid and "creating" or "waiting")
			end
		end)

		task.wait(0.05)
	end
end

goB.MouseButton1Click:Connect(function()
	RUN = not RUN
	if RUN then
		raidStart = tick() raids = 0 room = 0 done = false chestsDone = false creatingRaid = false activeUIDs = {} survivedFirstHit = {}
		goB.Text = "STOP" goB.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
		task.spawn(function()
			while RUN do pcall(boostLoop) if RUN then task.wait(2) end end
			st("OFF") rm("--") db("") tL.Text = ""
		end)
	else
		goB.Text = "START" goB.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
		tapOn = false tapB.Text = "360° Tap: OFF" tapB.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	end
end)
