    while true do
        pcall(function()
            countL.Text = tostring(dodges)
            local char = LocalPlayer.Character
            if char then
                local ev = char:GetAttribute("Evade")
                if ev ~= nil then
                    evadeL.Text = string.format("Evade: %d/50", math.floor(ev))
