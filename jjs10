-- ============================================
-- AUTO COUNTER — Eye Catching (Jujutsu Shenanigans)
-- Based on the working autoblock pattern
-- Uses keypress/keyrelease (NOT VIM)
-- ============================================

local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

local counterOn = false
local counters = 0
local lastFire = 0
local RANGE = 12

-- Key 3 = 0x33
local COUNTER_KEY = 0x33
pcall(function()
	local ec = character:FindFirstChild("Moveset") and character.Moveset:FindFirstChild("Eye Catching")
	if ec then
		local k = ec:GetAttribute("Key")
		if k == 1 then COUNTER_KEY = 0x31
		elseif k == 2 then COUNTER_KEY = 0x32
		elseif k == 3 then COUNTER_KEY = 0x33
		elseif k == 4 then COUNTER_KEY = 0x34 end
	end
end)

-- Non-combat anims (idle, walk, jump, fall, climb, sit)
local SAFE = {}
for _, id in {"180435571","180435792","15621270146","7012721719","180436334","9442520397","178130996"} do
	SAFE[id] = true
end

local function isCombatAnim(track)
	if not track or not track.Animation then return true end
	local id = track.Animation.AnimationId
	if not id then return true end
	local n = id:match("%d+")
	return not (n and SAFE[n])
end

local function fireCounter()
	if not counterOn then return end
	if (tick() - lastFire) < 0.3 then return end
	lastFire = tick()
	counters = counters + 1
	keypress(COUNTER_KEY)
	task.delay(0.15, function() keyrelease(COUNTER_KEY) end)
end

-- ============================================
-- MELEE: Same pattern as working autoblock
-- + filter combat anims + facing check
-- ============================================
local function watchPlayer(p)
	if p == LocalPlayer then return end
	local function onChar(char)
		pcall(function()
			local animator = char:WaitForChild("Humanoid"):WaitForChild("Animator")
			animator.AnimationPlayed:Connect(function(animTrack)
				if not counterOn then return end
				if not isCombatAnim(animTrack) then return end

				local myChar = LocalPlayer.Character
				if not myChar then return end
				local myRoot = myChar:FindFirstChild("HumanoidRootPart")
				local theirRoot = char:FindFirstChild("HumanoidRootPart")
				if not myRoot or not theirRoot then return end

				local dist = (myRoot.Position - theirRoot.Position).Magnitude
				if dist > RANGE then return end

				local toMe = (myRoot.Position - theirRoot.Position).Unit
				local dot = theirRoot.CFrame.LookVector:Dot(toMe)
				if dot > 0.3 then
					fireCounter()
				end
			end)
		end)
	end
	if p.Character then onChar(p.Character) end
	p.CharacterAdded:Connect(onChar)
end

for _, p in Players:GetPlayers() do watchPlayer(p) end
Players.PlayerAdded:Connect(watchPlayer)

-- ============================================
-- PROJECTILE: parts heading toward me
-- ============================================
pcall(function()
	local eff = workspace:FindFirstChild("Effects")
	if not eff then return end
	eff.ChildAdded:Connect(function(part)
		if not counterOn or not part:IsA("BasePart") then return end
		task.defer(function()
			for _ = 1, 10 do
				if not part.Parent then return end
				pcall(function()
					local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
					if not myRoot then return end
					local dist = (part.Position - myRoot.Position).Magnitude
					local vel = part.AssemblyLinearVelocity
					if vel.Magnitude > 10 and dist < 15 then
						local aimed = vel.Unit:Dot((myRoot.Position - part.Position).Unit)
						if aimed > 0.5 and dist / vel.Magnitude < 0.2 then
							fireCounter()
							return
						end
					end
				end)
				task.wait(0.03)
			end
		end)
	end)
end)

-- ============================================
-- REMOTE BACKUP: confirmed target
-- ============================================
pcall(function()
	for _, svc in RS.Knit.Knit.Services:GetChildren() do
		local re = svc:FindFirstChild("RE")
		if not re or svc.Name == "EyeCatchService" then continue end
		for _, remote in re:GetChildren() do
			if not remote:IsA("RemoteEvent") then continue end
			remote.OnClientEvent:Connect(function(...)
				if not counterOn then return end
				local myChar = LocalPlayer.Character
				for _, arg in {...} do
					if typeof(arg) == "Instance" and arg == myChar then
						fireCounter()
						return
					end
				end
			end)
		end
	end
end)

-- ============================================
-- RESPAWN
-- ============================================
LocalPlayer.CharacterAdded:Connect(function(char)
	character = char
	pcall(function()
		task.wait(1)
		local ec = char:FindFirstChild("Moveset") and char.Moveset:FindFirstChild("Eye Catching")
		if ec then
			local k = ec:GetAttribute("Key")
			if k == 1 then COUNTER_KEY = 0x31
			elseif k == 2 then COUNTER_KEY = 0x32
			elseif k == 3 then COUNTER_KEY = 0x33
			elseif k == 4 then COUNTER_KEY = 0x34 end
		end
	end)
end)

