-- ============================================================
-- MAIN LOOP
-- ============================================================
local function boostLoop()
	local emptyTime = 0
	local sawBreakables = false

	while RUN do
		pcall(function()
			local l = loc()
			local inRaid = (l == "R")

			if showTimer and raidStart > 0 and inRaid then
				tL.Text = string.format("%.0fs", tick() - raidStart)
			end

			if not raidOnly and not inRaid and not creatingRaid then
				st("Tapping...") rm(breakableCount() .. " targets") db("anywhere")
				task.wait(0.1)
				return
			end

			if not inRaid and not creatingRaid then
				st("Waiting...") db("loc=" .. l)
				chestsDone = false done = false emptyTime = 0 sawBreakables = false roomClears = 0
				task.wait(0.5)
				return
			end

			if creatingRaid then
				st("Creating...") db("transitioning")
				task.wait(0.3)
				return
			end

			-- Best guess at current room (event-based or fallback)
			local r = room
			if r < 1 then r = math.max(1, roomClears) end

			if not done then
				local bc = breakableCount()
				st("Room " .. r)
				rm(bc .. " | b=" .. (r >= 10 and "50" or tostring(burst)) .. "x")

				if bc > 0 then
					sawBreakables = true
					emptyTime = 0

					-- TP for rooms 8+
					if r >= 8 then
						local nearPos, nearDist, alive = findNearest()
						if nearPos then
							tp(Vector3.new(nearPos.X, 108, nearPos.Z))
						end
						db(alive .. " alive | d=" .. string.format("%.0f", nearDist or 0))
					else
						db(bc .. " targets")
					end
				else
					if sawBreakables then emptyTime = emptyTime + 0.05 end
					if r >= 10 and sawBreakables and emptyTime > 2 then done = true end
					db("empty " .. string.format("%.1f", emptyTime) .. "s")
				end

			elseif not chestsDone then
				st("Chests + Next!")
				tp(CHEST_POS)
				chestsDone = true
				raids = raids + 1
				if showTimer and raidStart > 0 then tL.Text = string.format("Last: %.0fs", tick() - raidStart) end
				rm("Raids: " .. raids)
				task.spawn(openChestsAndCreate)

			else
				st("Next raid...")
				db(creatingRaid and "creating" or "waiting")
			end
		end)

		task.wait(0.05)
	end
end

