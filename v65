-- ============================================================
-- CACHED UID SYSTEM
-- Stores uid -> model reference so we can check health cheaply
-- ============================================================
local activeBreakables = {} -- uid -> model

local function onAdded(b)
	local uid = b:GetAttribute("BreakableUID")
	if not uid then return end
	activeBreakables[uid] = b

	-- Instant kill on spawn
	if tapOn and SignalMod then
		local n = burst
		if n == math.huge then n = 999 end
		for _ = 1, n do
			SignalMod.Fire("AutoClicker_Nearby", uid)
		end
	end
end

local function onRemoved(b)
	local uid = b:GetAttribute("BreakableUID")
	if uid then activeBreakables[uid] = nil end
end

for _, folder in {"Breakables", "AnimatedBreakables"} do
	pcall(function()
		for _, b in workspace.__THINGS[folder]:GetChildren() do onAdded(b) end
		workspace.__THINGS[folder].ChildAdded:Connect(onAdded)
		workspace.__THINGS[folder].ChildRemoved:Connect(onRemoved)
	end)
end

