status.TextXAlignment = Enum.TextXAlignment.Left
status.TextColor3 = Color3.fromRGB(180, 180, 180)
status.TextSize = 14
status.Font = Enum.Font.SourceSans
status.Text = ""
status.Parent = main

local lines = {}
local function rebuildText()
    output.Text = table.concat(lines, "\n")
    output.CursorPosition = #output.Text + 1
end

local function addLine(messageType, message)
    local prefix = "[" .. tostring(messageType) .. "] "
    table.insert(lines, prefix .. message)
    if #lines > 300 then
        table.remove(lines, 1)
    end
    rebuildText()
end

LogService.MessageOut:Connect(function(message, messageType)
    addLine(messageType.Name, message)
end)

copyButton.MouseButton1Click:Connect(function()
    local text = output.Text
    if typeof(setclipboard) == "function" then
        pcall(function() setclipboard(text) end)
        status.Text = "Copied to clipboard."
    else
        output:CaptureFocus()
        output.SelectionStart = 1
        output.CursorPosition = #text + 1
        status.Text = "Clipboard is unavailable here. Text is selected."
    end
    task.delay(2, function() status.Text = "" end)
end)

clearButton.MouseButton1Click:Connect(function()
    lines = {}
    rebuildText()
    status.Text = "Cleared."
    task.delay(2, function() status.Text = "" end)
end)

-- ============================================
-- DRAG — attached to title bar only (so textbox still works)
-- ============================================
local dragging = false
local dragStart, startPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)
