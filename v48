-- ============================================================
-- MAIN LOOP
-- ============================================================
local function boostLoop()
	local emptyTime = 0
	local sawBreakables = false
	local lastBlitzRoom = 0

	while RUN do
		local l = loc()

		if l ~= "R" and not creatingRaid then
			st("Waiting...") db("loc=" .. l)
			chestsDone = false done = false emptyTime = 0 sawBreakables = false locallyDead = {} currentTarget = nil lastBlitzRoom = 0
			task.wait(0.5)

		elseif creatingRaid then
			st("Creating...") db("transitioning")
			task.wait(0.3)

		else
			if showTimer and raidStart > 0 then tL.Text = string.format("%.0fs", tick() - raidStart) end

			if not done then
				local r = room if r < 1 then r = 1 end
				st("Room " .. r)

				if r <= 8 then
					-- ===== BLITZ MODE: rooms 1-8 =====
					-- Just sweep all positions fast, tap everything, no health checks
					local positions = getAllPositions()
					rm(#positions .. " targets")

					if #positions > 0 then
						sawBreakables = true
						emptyTime = 0

						-- TP to nearest, tap, done. Blitz handles the rest.
						-- Only full blitz sweep when entering new room
						if r ~= lastBlitzRoom then
							lastBlitzRoom = r
							db("BLITZ!")
							blitzRoom()
						else
							-- Between blitz sweeps: just tap everything from current pos
							if tapOn then tapAll() end
							db("tapping")
						end
					else
						if sawBreakables then emptyTime = emptyTime + 0.03 end
						db("waiting")
					end

				else
					-- ===== SMART MODE: rooms 9-10 =====
					-- Health tracking, predictive dead, TP to nearest alive
					if tapOn then tapAll() end

					local nearPos, nearDist, alive, nearObj = smartScan()
					rm(alive .. " alive")

					if alive > 0 and nearPos then
						sawBreakables = true
						emptyTime = 0
						if nearObj ~= currentTarget then
							currentTarget = nearObj
							tp(Vector3.new(nearPos.X, 108, nearPos.Z))
						end
						db(alive .. " | d=" .. string.format("%.0f", nearDist))
					else
						currentTarget = nil
						if sawBreakables then emptyTime = emptyTime + 0.03 end
						if sawBreakables and emptyTime > 2 then done = true end
						db("empty " .. string.format("%.1f", emptyTime) .. "s")
					end
				end

			elseif not chestsDone then
				st("Chests!")
				tp(CHEST_POS)
				task.wait(0.5)
				openChests()
				task.wait(1)
				chestsDone = true
				raids = raids + 1
				if showTimer and raidStart > 0 then tL.Text = string.format("Last: %.0fs", tick() - raidStart) end
				rm("Raids: " .. raids)
				task.spawn(createNewRaid)

			else
				st("Next raid...")
				db(creatingRaid and "creating" or "waiting")
			end

			task.wait(0.03)
		end
	end
end

