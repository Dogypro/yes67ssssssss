local sg = Instance.new("ScreenGui", player.PlayerGui)
sg.Name = "AutoCounterV11"
local f = Instance.new("Frame", sg)
f.Size = UDim2.new(0, 150, 0, 100)
f.Position = UDim2.new(0.8, 0, 0.2, 0)
f.BackgroundColor3 = Color3.fromRGB(20, 20, 25)

local function createBtn(text, pos, callback)
    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(1, -10, 0, 35)
    b.Position = pos
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    b.TextColor3 = Color3.new(1,1,1)
    b.MouseButton1Click:Connect(callback)
    return b
end

local bB = createBtn("Before: OFF", UDim2.new(0, 5, 0, 10), function()
    beforeOn = not beforeOn
    _G.btnB.Text = "Before: " .. (beforeOn and "ON" or "OFF")
    _G.btnB.BackgroundColor3 = beforeOn and Color3.fromRGB(100, 50, 150) or Color3.fromRGB(40, 40, 50)
end)
_G.btnB = bB

local bR = createBtn("React: OFF", UDim2.new(0, 5, 0, 50), function()
    reactOn = not reactOn
    _G.btnR.Text = "React: " .. (reactOn and "ON" or "OFF")
    _G.btnR.BackgroundColor3 = reactOn and Color3.fromRGB(150, 50, 50) or Color3.fromRGB(40, 40, 50)
end)
_G.btnR = bR
