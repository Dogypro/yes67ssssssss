local AI_KEY      = "" -- put your key here if you enable AI
local AI_MODEL    = "gpt-4o-mini"

-- ============================================
-- SCRIPT COLLECTION
-- We scan containers a LocalScript can realistically read from.
-- Server Scripts' .Source is not readable from the client in live games;
-- this script surfaces whatever IS readable (ModuleScripts, LocalScripts).
-- ============================================
local SCAN_ROOTS = {
    game:GetService("ReplicatedStorage"),
    game:GetService("ReplicatedFirst"),
    game:GetService("StarterPlayer"),
    game:GetService("StarterGui"),
    game:GetService("StarterPack"),
    game:GetService("Lighting"),
    game:GetService("Workspace"),
    LocalPlayer:FindFirstChild("PlayerGui"),
    LocalPlayer:FindFirstChild("PlayerScripts"),
    LocalPlayer.Character,
}

local function collectScripts()
    local found = {}
    local seen = {}
    for _, root in SCAN_ROOTS do
        if root then
            for _, inst in root:GetDescendants() do
                if (inst:IsA("LocalScript") or inst:IsA("ModuleScript") or inst:IsA("Script"))
                    and not seen[inst] then
                    seen[inst] = true
                    table.insert(found, inst)
                end
            end
        end
    end
    return found
end

local function tryReadSource(script)
    local ok, src = pcall(function() return script.Source end)
    if ok and type(src) == "string" and #src > 0 then
        return src
    end
    -- decompile fallback (available in executor environments)
    if decompile then
        local ok2, src2 = pcall(decompile, script)
        if ok2 and type(src2) == "string" and #src2 > 0 then
            return src2
        end
    end
    return nil
end

-- ============================================
-- HEURISTIC SUMMARIZER
-- Pulls out structural signals: services used, remotes, keybinds, functions, etc.
-- ============================================
local function summarizeHeuristic(source, name)
    local lines = {}
    local function add(s) table.insert(lines, s) end

    local loc = select(2, source:gsub("\n", "\n")) + 1

    -- services
    local services = {}
    for svc in source:gmatch('GetService%(%s*"([%w_]+)"') do services[svc] = true end
    local svcList = {}
    for s in pairs(services) do table.insert(svcList, s) end
    table.sort(svcList)

    -- remotes
    local remotes = {}
    for pattern in source:gmatch('([%w_]+):FireServer') do remotes[pattern .. ":FireServer"] = true end
    for pattern in source:gmatch('([%w_]+):InvokeServer') do remotes[pattern .. ":InvokeServer"] = true end
    for pattern in source:gmatch('([%w_]+)%.OnClientEvent') do remotes[pattern .. ".OnClientEvent"] = true end

    -- keybinds / input
    local keys = {}
    for k in source:gmatch('KeyCode%.([%w_]+)') do keys[k] = true end

    -- functions defined
    local funcs = {}
    for f in source:gmatch('function%s+([%w_:%.]+)%s*%(') do table.insert(funcs, f) end
    for f in source:gmatch('local%s+function%s+([%w_]+)%s*%(') do table.insert(funcs, f) end

    -- interesting flags
    local flags = {}
    if source:find("HttpGet") or source:find("HttpPost") or source:find("request%s*%(") then
        table.insert(flags, "makes HTTP requests")
    end
    if source:find("loadstring") then table.insert(flags, "uses loadstring") end
    if source:find("RunService") and (source:find("RenderStepped") or source:find("Heartbeat") or source:find("Stepped")) then
        table.insert(flags, "runs every frame")
    end
    if source:find("UserInputService") or source:find("ContextActionService") then
        table.insert(flags, "handles input")
    end
    if source:find("TweenService") then table.insert(flags, "uses tweens") end
    if source:find("workspace:Raycast") or source:find("FindPartOnRay") then
        table.insert(flags, "raycasts")
    end
    if source:find("Instance%.new%(%s*\"ScreenGui\"") or source:find(":WaitForChild%(\"PlayerGui\"") then
        table.insert(flags, "creates GUI")
    end
    if source:find("BodyVelocity") or source:find("LinearVelocity") or source:find("AlignPosition") then
        table.insert(flags, "manipulates physics/movement")
    end
    if source:find("Humanoid") and (source:find(":Move%(") or source:find("%.WalkSpeed") or source:find("%.JumpPower")) then
        table.insert(flags, "controls Humanoid")
    end

    -- comments at top (often explain intent)
    local firstComments = {}
    for line in source:gmatch("[^\n]+") do
        local stripped = line:match("^%s*(.-)%s*$")
        if stripped:sub(1, 2) == "--" then
            table.insert(firstComments, stripped)
            if #firstComments >= 3 then break end
        elseif stripped ~= "" then
            break
        end
    end

    -- assemble
    add("• Lines: " .. loc)
    if #firstComments > 0 then
        add("• Header comments: " .. table.concat(firstComments, " | "):sub(1, 200))
    end
    if #svcList > 0 then
        add("• Services: " .. table.concat(svcList, ", "))
    end
    local remoteList = {}
    for r in pairs(remotes) do table.insert(remoteList, r) end
    if #remoteList > 0 then
        table.sort(remoteList)
        add("• Remotes: " .. table.concat(remoteList, ", "):sub(1, 300))
    end
    local keyList = {}
    for k in pairs(keys) do table.insert(keyList, k) end
    if #keyList > 0 then
        table.sort(keyList)
        add("• Keybinds: " .. table.concat(keyList, ", "))
    end
    if #funcs > 0 then
        local shown = {}
        for i = 1, math.min(8, #funcs) do table.insert(shown, funcs[i]) end
        add("• Functions (" .. #funcs .. "): " .. table.concat(shown, ", "))
    end
    if #flags > 0 then
        add("• Behavior: " .. table.concat(flags, "; "))
    end

    return table.concat(lines, "\n")
end

-- ============================================
-- OPTIONAL AI SUMMARIZER (OpenAI-compatible)
-- ============================================
local function summarizeAI(source, name)
    if not AI_ENABLED or AI_KEY == "" then return nil end
    local req = request or http_request or (syn and syn.request)
    if not req then return nil end

    -- truncate massive files to keep token cost down
    local snippet = source
    if #snippet > 8000 then
        snippet = snippet:sub(1, 6000) .. "\n\n-- [truncated] --\n\n" .. snippet:sub(-1500)
    end

    local body = HttpService:JSONEncode({
        model = AI_MODEL,
        messages = {
            { role = "system", content = "You are summarizing Roblox Luau scripts. Give a 2-4 sentence summary focused on: what the script does, what it interacts with (remotes, services, input), and anything notable about its behavior. Be concise." },
            { role = "user", content = "Script name: " .. name .. "\n\n" .. snippet }
        },
        max_tokens = 200,
        temperature = 0.3,
    })

    local ok, res = pcall(req, {
        Url = AI_ENDPOINT,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. AI_KEY,
        },
        Body = body,
    })
    if not ok or not res or not res.Body then return nil end
    local ok2, parsed = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not ok2 or not parsed or not parsed.choices then return nil end
    return parsed.choices[1] and parsed.choices[1].message and parsed.choices[1].message.content
end

