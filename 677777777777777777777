summarizeAllBtn.MouseButton1Click:Connect(function()
    if #scannedScripts == 0 then
        setStatus("Scan first.", Color3.fromRGB(230, 150, 80))
        return
    end
    setStatus("Summarizing all " .. #scannedScripts .. "...")
    task.spawn(function()
        local out = {}
        for i, s in scannedScripts do
            local src = tryReadSource(s)
            local path = getScriptPath(s)
            table.insert(out, "=== " .. path .. " (" .. s.ClassName .. ") ===")
            if src then
                table.insert(out, summarizeHeuristic(src, s.Name))
            else
                table.insert(out, "  [no readable source]")
            end
            table.insert(out, "")
            if i % 20 == 0 then
                setStatus("Summarizing... " .. i .. "/" .. #scannedScripts)
                task.wait()
            end
        end
        allSummaries = table.concat(out, "\n")
        currentSummary = allSummaries
        summaryHeader.Text = "All scripts (" .. #scannedScripts .. ")"
        -- Display truncated, full content still in currentSummary for copy/save
        local display = allSummaries
        if #display > 60000 then
            display = display:sub(1, 60000) .. "\n\n-- [truncated in view, full content in Copy/Save] --"
        end
        summaryLabel.Text = display
        setStatus("Done. " .. #scannedScripts .. " scripts summarized.", Color3.fromRGB(120, 220, 120))
    end)
end)

copyBtn.MouseButton1Click:Connect(function()
    if currentSummary == "" then setStatus("Nothing to copy.", Color3.fromRGB(230, 150, 80)) return end
    local ok = pcall(function()
        if setclipboard then setclipboard(currentSummary)
        elseif toclipboard then toclipboard(currentSummary)
        else error("no clipboard fn") end
    end)
    if ok then
        setStatus("Copied " .. #currentSummary .. " chars.", Color3.fromRGB(120, 220, 120))
    else
        setStatus("Clipboard unavailable — use Save File.", Color3.fromRGB(230, 150, 80))
    end
end)

saveBtn.MouseButton1Click:Connect(function()
    if currentSummary == "" then setStatus("Nothing to save.", Color3.fromRGB(230, 150, 80)) return end
    if not writefile then setStatus("writefile unavailable.", Color3.fromRGB(230, 80, 80)) return end
    local fname = "script_summary.txt"
    local ok, err = pcall(writefile, fname, currentSummary)
    if ok then
        setStatus("Saved to workspace/" .. fname, Color3.fromRGB(120, 220, 120))
    else
        setStatus("Save failed: " .. tostring(err), Color3.fromRGB(230, 80, 80))
    end
end)

