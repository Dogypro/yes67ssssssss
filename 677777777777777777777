-- STATE + ACTIONS
-- ============================================
local scannedScripts = {}
local currentSummary = ""
local allSummaries = ""

local function setStatus(txt, color)
    statusLabel.Text = txt
    statusLabel.TextColor3 = color or Color3.fromRGB(160, 160, 170)
end

local function getScriptPath(inst)
    local parts = {}
    local cur = inst
    while cur and cur ~= game do
        table.insert(parts, 1, cur.Name)
        cur = cur.Parent
    end
    return table.concat(parts, ".")
end

local function rebuildList(filter)
    for _, c in scriptList:GetChildren() do
        if c:IsA("TextButton") then c:Destroy() end
    end
    filter = (filter or ""):lower()
    for i, s in scannedScripts do
        local path = getScriptPath(s)
        if filter == "" or path:lower():find(filter, 1, true) then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -4, 0, 24)
            btn.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
            btn.Text = "  " .. s.ClassName:sub(1, 1) .. " | " .. s.Name
            btn.TextColor3 = Color3.fromRGB(220, 220, 230)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 11
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.BorderSizePixel = 0
            btn.Parent = scriptList
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)
            btn.MouseButton1Click:Connect(function()
                setStatus("Summarizing: " .. s.Name)
                summaryHeader.Text = path
                local src = tryReadSource(s)
                if not src then
                    currentSummary = "Source not readable (likely a server Script with protected source)."
                    summaryLabel.Text = currentSummary
                    setStatus("No readable source for " .. s.Name, Color3.fromRGB(230, 150, 80))
                    return
                end
                local heur = summarizeHeuristic(src, s.Name)
                currentSummary = heur
                summaryLabel.Text = heur .. "\n\n-- Preview (first 1000 chars) --\n" .. src:sub(1, 1000)
                setStatus("Summarized " .. s.Name, Color3.fromRGB(120, 220, 120))

                if AI_ENABLED then
                    task.spawn(function()
                        local ai = summarizeAI(src, s.Name)
                        if ai then
                            currentSummary = "AI Summary:\n" .. ai .. "\n\nSignals:\n" .. heur
                            summaryLabel.Text = currentSummary .. "\n\n-- Preview --\n" .. src:sub(1, 1000)
                        end
                    end)
                end
            end)
        end
    end
end

