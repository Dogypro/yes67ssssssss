-- ============================================================
-- MAIN LOOP
-- ============================================================
local function boostLoop()
	local emptyTime = 0
	local sawBreakables = false

	while RUN do
		pcall(function()
			local l = loc()
			local inRaid = (l == "R")

			if showTimer and raidStart > 0 and inRaid then
				tL.Text = string.format("%.0fs", tick() - raidStart)
			end

			if not raidOnly and not inRaid and not creatingRaid then
				st("Tapping...")
				local _, _, alive = scanBreakables()
				rm(alive .. " targets") db("anywhere")
				task.wait(0.1)
				return
			end

			if not inRaid and not creatingRaid then
				st("Waiting...") db("loc=" .. l)
				chestsDone = false done = false emptyTime = 0 sawBreakables = false
				task.wait(0.5)
				return
			end

			if creatingRaid then
				st("Creating...") db("transitioning")
				task.wait(0.3)
				return
			end

			local r = room if r < 1 then r = 1 end

			if not done then
				local nearPos, nearDist, alive = scanBreakables()

				st("Room " .. r)
				rm(alive .. " alive")

				if alive > 0 then
					sawBreakables = true
					emptyTime = 0
					if r >= 4 and nearPos then
						tp(nearPos)
					end
					db(alive .. " | d=" .. string.format("%.0f", nearDist or 0))
				else
					if sawBreakables then emptyTime = emptyTime + 0.05 end
					if r >= 10 and sawBreakables and emptyTime > 1.5 then done = true end
					db("empty " .. string.format("%.1f", emptyTime) .. "s")
				end

			elseif not chestsDone then
				st("Chests + Next!")
				tp(CHEST_POS)
				chestsDone = true
				raids = raids + 1
				if showTimer and raidStart > 0 then tL.Text = string.format("Last: %.0fs", tick() - raidStart) end
				rm("Raids: " .. raids)
				task.spawn(openChestsAndCreate)

			else
				st("Next raid...")
				db(creatingRaid and "creating" or "waiting")
			end
		end)

		task.wait(0.05)
	end
end

goB.MouseButton1Click:Connect(function()
