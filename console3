local copyButton = Instance.new("TextButton")
copyButton.Size = UDim2.new(0, 110, 0, 28)
copyButton.Position = UDim2.new(1, -120, 1, -34)
copyButton.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
copyButton.BorderSizePixel = 0
copyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
copyButton.TextSize = 16
copyButton.Font = Enum.Font.SourceSansSemibold
copyButton.Text = "Copy"
copyButton.Parent = main

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -140, 0, 28)
status.Position = UDim2.new(0, 10, 1, -34)
status.BackgroundTransparency = 1
status.TextXAlignment = Enum.TextXAlignment.Left
status.TextColor3 = Color3.fromRGB(180, 180, 180)
status.TextSize = 14
status.Font = Enum.Font.SourceSans
status.Text = ""
status.Parent = main

local lines = {}

local function rebuildText()
	output.Text = table.concat(lines, "\n")
	output.CursorPosition = #output.Text + 1
end

local function addLine(messageType, message)
	local prefix = "[" .. tostring(messageType) .. "] "
	table.insert(lines, prefix .. message)

	if #lines > 300 then
		table.remove(lines, 1)
	end

	rebuildText()
end

LogService.MessageOut:Connect(function(message, messageType)
	addLine(messageType.Name, message)
end)

copyButton.MouseButton1Click:Connect(function()
	local text = output.Text

	if typeof(setclipboard) == "function" then
		pcall(function()
			setclipboard(text)
		end)
		status.Text = "Copied to clipboard."
	else
		output:CaptureFocus()
		output.SelectionStart = 1
		output.CursorPosition = #text + 1
		status.Text = "Clipboard is unavailable here. Text is selected."
	end

	task.delay(2, function()
		status.Text = ""
	end)
end)
