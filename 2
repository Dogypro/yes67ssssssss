-- ============================================================
-- MAIN LOOP
-- ============================================================
local function boostLoop()
	local emptyTime = 0
	local sawBreakables = false
	local lastRoom = 0
	local preTped = false
	local boss1Done = false
	local boss2Done = false
	local boss3Done = false

	while RUN do
		pcall(function()
			local l = loc()
			local inRaid = (l == "R")

			if showTimer and raidStart > 0 and inRaid then tL.Text = string.format("%.0fs", tick() - raidStart) end

			if not inRaid and not creatingRaid then
				st("Waiting...") db("loc=" .. l)
				chestsDone = false done = false emptyTime = 0 sawBreakables = false lastRoom = 0 preTped = false
				boss1Done = false boss2Done = false boss3Done = false bossData = {}
				task.wait(0.5) return
			end

			if creatingRaid then st("Creating...") db("transitioning") task.wait(0.3) return end

			local r = room if r < 1 then r = 1 end

			if r ~= lastRoom then
				lastRoom = r preTped = false sawBreakables = false emptyTime = 0

				-- Boss 1 after room 3
				if doBosses and r > 3 and not boss1Done then
					boss1Done = true
					st("Boss 1!")
					pcall(doBoss, 1)
				end

				-- Boss 2 after room 9
				if doBosses and r > 9 and not boss2Done then
					boss2Done = true
					st("Boss 2!")
					pcall(doBoss, 2)
				end
			end

			if not done then
				local nearPos, nearDist, total, aliveCount = scanForTP()

				st("Room " .. r)
				rm(aliveCount .. "/" .. total .. " alive")

				if total > 0 and nearPos then
					sawBreakables = true emptyTime = 0 preTped = false
					if r >= 4 then tp(nearPos) end
					db("d=" .. string.format("%.0f", nearDist))
				elseif total == 0 then
					if sawBreakables then emptyTime = emptyTime + 0.05 end
					if not preTped then
						if r < 10 and ROOM_POS[r + 1] then
							tp(ROOM_POS[r + 1]) preTped = true db("PRE-TP room " .. (r+1))
						elseif r >= 10 then
							tp(CHEST_POS) preTped = true db("PRE-TP chests")
						end
					else
						db("waiting " .. string.format("%.1f", emptyTime) .. "s")
					end
					if r >= 10 and sawBreakables and emptyTime > 1.5 then done = true end
				end

			elseif not chestsDone then
				-- Boss 3 after completion (before chests so we're still in raid)
				if doBosses and not boss3Done then
					boss3Done = true
					st("Boss 3!")
					pcall(doBoss, 3)
				end

				st("Chests + Next!")
				tp(CHEST_POS)
				chestsDone = true
				raids = raids + 1
				if showTimer and raidStart > 0 then tL.Text = string.format("Last: %.0fs", tick() - raidStart) end
				rm("Raids: " .. raids)
				task.spawn(openChestsAndCreate)

			else
				st("Next raid...") db(creatingRaid and "creating" or "waiting")
			end
		end)

		task.wait(0.05)
	end
end

