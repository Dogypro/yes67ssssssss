-- ============================================================
-- MAIN LOOP
-- ============================================================
local function boostLoop()
	local emptyTime = 0
	local sawBreakables = false

	while RUN do
		pcall(function()
			local l = loc()
			local inRaid = (l == "R")

			if showTimer and raidStart > 0 and inRaid then
				tL.Text = string.format("%.0fs", tick() - raidStart)
			end

			-- TAP anywhere mode: just tap whenever, no TP logic
			if not raidOnly and not inRaid then
				st("Tapping...")
				local _, _, total = findNearest()
				rm(total .. " targets")
				db("anywhere mode")
				task.wait(0.05)
				return
			end

			if not inRaid and not creatingRaid then
				st("Waiting...") db("loc=" .. l)
				chestsDone = false done = false emptyTime = 0 sawBreakables = false
				task.wait(0.5)
				return
			end

			if creatingRaid then
				st("Creating...") db("transitioning")
				task.wait(0.3)
				return
			end

			-- IN RAID
			if not done then
				local r = room if r < 1 then r = 1 end
				st("Room " .. r)

				-- STEP 1: Find nearest breakable position FIRST
				local nearPos, nearDist, total = findNearest()
				rm(total .. " targets")

				-- STEP 2: TP to it
				if total > 0 and nearPos then
					sawBreakables = true
					emptyTime = 0
					tp(Vector3.new(nearPos.X, 108, nearPos.Z))
					db(total .. " | d=" .. string.format("%.0f", nearDist))
				else
					if sawBreakables then emptyTime = emptyTime + 0.03 end
					if r >= 10 and sawBreakables and emptyTime > 2 then done = true end
					db("empty " .. string.format("%.1f", emptyTime) .. "s")
				end

			elseif not chestsDone then
				st("Chests!")
				tp(CHEST_POS)
				task.wait(0.5)
				openChests()
				task.wait(1)
				chestsDone = true
				raids = raids + 1
				if showTimer and raidStart > 0 then tL.Text = string.format("Last: %.0fs", tick() - raidStart) end
				rm("Raids: " .. raids)
				task.spawn(createNewRaid)

			else
				st("Next raid...")
				db(creatingRaid and "creating" or "waiting")
			end
		end)

		task.wait(0.03)
	end
end

